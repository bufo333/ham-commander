# C64 Ham Log Server Configuration

# Server listen address and port
LISTEN_HOST=0.0.0.0
LISTEN_PORT=6400

# QRZ.com credentials (for callsign lookups)
# Get your account at https://www.qrz.com
QRZ_USERNAME=your_callsign
QRZ_PASSWORD=your_password

# QRZ Logbook API key (for logbook operations)
# Get your key at https://logbook.qrz.com/logbook
QRZ_API_KEY=XXXX-XXXX-XXXX-XXXX

# Your station callsign
MY_CALLSIGN=N0CALL
